# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# DeepSeek (or any OpenAI-compatible) API key
LLM_API_KEY=your-api-key-here

# Base URL of the LLM provider (OpenAI-compatible endpoint)
# DeepSeek: https://api.deepseek.com/v1  or  https://api.deepseek.com/anthropic
LLM_BASE_URL=https://api.deepseek.com/v1

# Model name to use
LLM_MODEL=deepseek-chat

# Vision model for image OCR (optional, falls back to Tesseract if not set)
# Uses same API key as LLM_API_KEY unless VISION_API_KEY is set
VISION_MODEL=
VISION_API_KEY=
VISION_BASE_URL=
